<AnchorPane prefHeight="669.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="echo.MainWindow">
   <children>
       <ScrollPane fx:id="scrollPane" fitToWidth="true" layoutX="-3.0" layoutY="-3.0" prefHeight="612.0" prefWidth="606.0">
       <content>
           <VBox fx:id="dialogueContainer" prefHeight="612.0" />
         </content>
      </ScrollPane>
      <TextField fx:id="userInput" layoutX="10.0" layoutY="618.0" onAction="#handleUserInput" prefHeight="36.0" prefWidth="520.0" />
      <Button fx:id="sendButton" layoutX="541.0" layoutY="623.0" mnemonicParsing="false" onAction="#handleUserInput" text="Enter" />
   </children>
</AnchorPane>
